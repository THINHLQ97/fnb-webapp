// Prisma schema — CHỈ chứa dữ liệu KiotViet KHÔNG quản lý:
//   bài viết (CMS), nhân sự, chấm công, lịch trực, tài khoản & phân quyền.
// Doanh số / tồn kho / đơn hàng KHÔNG lưu ở đây — luôn đọc trực tiếp từ KiotViet.
//
// Chạy:  npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----- Tài khoản & phân quyền (RBAC) -----
enum Role {
  ADMIN // chủ / quản lý: toàn quyền
  EDITOR // biên tập viên: chỉ quản lý bài viết
  MANAGER // quản lý ca: chấm công, xếp lịch
  STAFF // nhân viên: xem lịch của mình, check-in/out
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?
  emailVerified DateTime?
  role          Role      @default(STAFF)
  accounts      Account[]
  employee      Employee?
  posts         Post[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Auth.js — liên kết OAuth (Google, v.v.)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ----- CMS bài viết (yêu cầu: admin biên tập & chỉnh sửa bài) -----
enum PostStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String?
  content     Json // lưu rich-text (TipTap/Lexical) dạng JSON
  coverImage  String?
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  author      User       @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
}

// ----- Nhân sự (database nhân viên, phân công) -----
model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  employees Employee[]
}

model Employee {
  id           String            @id @default(cuid())
  code         String            @unique
  fullName     String
  phone        String?
  position     String?
  department   Department?       @relation(fields: [departmentId], references: [id])
  departmentId String?
  user         User?             @relation(fields: [userId], references: [id])
  userId       String?           @unique
  active       Boolean           @default(true)
  hiredAt      DateTime?
  shifts       ShiftAssignment[]
  attendances  Attendance[]
  createdAt    DateTime          @default(now())
}

// ----- Lịch trực / ca làm -----
model Shift {
  id          String            @id @default(cuid())
  name        String
  startTime   String
  endTime     String
  assignments ShiftAssignment[]
}

model ShiftAssignment {
  id         String   @id @default(cuid())
  shift      Shift    @relation(fields: [shiftId], references: [id])
  shiftId    String
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  date       DateTime
  note       String?

  @@unique([employeeId, date, shiftId])
  @@index([date])
}

// ----- Chấm công -----
model Attendance {
  id         String    @id @default(cuid())
  employee   Employee  @relation(fields: [employeeId], references: [id])
  employeeId String
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  source     String    @default("web")
  note       String?

  @@unique([employeeId, date])
  @@index([date])
}

// ----- Cấu hình website (hero, contact, giờ mở cửa) -----
// Key-value, value là JSON để linh hoạt. Admin sửa qua UI, web đọc runtime.
model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ----- Menu overlay: đè metadata lên sản phẩm KiotViet -----
// KiotViet là nguồn sự thật cho tên/giá; đây chỉ thêm tag, ảnh custom,
// đánh dấu highlight/featured để marketing.
model MenuItemOverride {
  id          String   @id @default(cuid())
  kiotvietId  Int      @unique
  highlight   Boolean  @default(false) // hiển thị badge "Best seller"
  featured    Boolean  @default(false) // ghim lên đầu danh sách menu
  customImage String?
  tag         String? // "MỚI", "GIẢM 20%", "HOT"...
  note        String? // ghi chú nội bộ cho quản lý
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured])
  @@index([highlight])
}
